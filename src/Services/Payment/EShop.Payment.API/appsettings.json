{
  "ConnectionStrings": {
    "PaymentDb": "Host=localhost;Port=5436;Database=eshop_payment;Username=postgres;Password=CHANGE_ME_payment_postgres_password;MaxPoolSize=40;Timeout=30;Command Timeout=30"
  },
  "RabbitMQ": {
    "Host": "",
    "Port": 5672,
    "Username": "",
    "Password": "",
    "VirtualHost": "/"
  },
  "PaymentSimulation": {
    "ProcessingDelayMinSeconds": 1,
    "ProcessingDelayMaxSeconds": 3,
    "SuccessRatePercent": 80,
    "RefundDelaySeconds": 2
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_payment_service_secret_key_32_chars_min",
    "Issuer": "EShop.Identity",
    "Audience": "EShop.Services"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://localhost:4317",
    "SamplingRatio": 0.1,
    "MetricsEnabled": true
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
