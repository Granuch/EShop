{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}      {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/notification-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "apiKey": ""
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithEnvironmentName" ]
  },
  "ConnectionStrings": {
    "NotificationDb": "",
    "Redis": ""
  },
  "RabbitMQ": {
    "Host": "",
    "Port": 5672,
    "Username": "",
    "Password": "",
    "VirtualHost": "/",
    "UseSsl": false,
    "ConcurrencyLimit": 10,
    "PrefetchCount": 16,
    "RetryCount": 3,
    "RetryIntervalSeconds": 5,
    "RetryIncrementSeconds": 5,
    "CircuitBreakerThreshold": 50,
    "CircuitBreakerActiveThreshold": 10,
    "CircuitBreakerDurationSeconds": 30,
    "HeartbeatIntervalSeconds": 30,
    "ClusterNodes": [],
    "UseDelayedRedelivery": true,
    "DelayedRedeliveryIntervalsMinutes": [ 1, 5, 15 ]
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "UseSsl": true,
    "FromEmail": "noreply@eshop.local",
    "FromName": "EShop"
  },
  "IdentityService": {
    "BaseUrl": "",
    "TimeoutSeconds": 5,
    "ApiKey": "LOCAL_internal_service_api_key",
    "ApiKeyHeaderName": "X-Internal-Api-Key"
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://localhost:4317",
    "SamplingRatio": 0.1,
    "MetricsEnabled": true
  }
}
