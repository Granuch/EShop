{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "NotificationDb": "Host=localhost;Port=5435;Database=eshop_notification;Username=postgres;Password=CHANGE_ME_notification_postgres_password;MaxPoolSize=40;Timeout=30;Command Timeout=30"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "CHANGE_ME_rabbitmq_user",
    "Password": "CHANGE_ME_rabbitmq_password",
    "RetryCount": 3,
    "RetryIntervalSeconds": 5,
    "RetryIncrementSeconds": 5,
    "UseDelayedRedelivery": true,
    "DelayedRedeliveryIntervalsMinutes": [ 1, 5, 15 ]
  },
  "Smtp": {
    "Host": "smtp.mailtrap.io",
    "Port": 587,
    "UseSsl": true,
    "FromEmail": "noreply@eshop.local",
    "FromName": "EShop"
  },
  "IdentityService": {
    "BaseUrl": "http://localhost:7001",
    "TimeoutSeconds": 5,
    "ApiKey": "LOCAL_internal_service_api_key",
    "ApiKeyHeaderName": "X-Internal-Api-Key"
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://localhost:4317",
    "SamplingRatio": 0.1,
    "MetricsEnabled": true
  }
}
