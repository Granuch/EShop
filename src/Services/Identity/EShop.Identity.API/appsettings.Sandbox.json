{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "EShop": "Debug",
        "EShop.BuildingBlocks.Infrastructure.Behaviors.CachingBehavior": "Debug",
        "EShop.BuildingBlocks.Infrastructure.Behaviors.CacheInvalidationBehavior": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}      {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/identity-sandbox-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://seq:5341",
          "apiKey": ""
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithEnvironmentName" ]
  },
  "ConnectionStrings": {
    "IdentityDb": "Host=postgres;Port=5432;Database=eshop_identity;Username=postgres;Password=LOCAL_ONLY_REPLACE_ME",
    "Redis": "redis:6379,password=LOCAL_ONLY_REPLACE_ME,ssl=false,abortConnect=false,connectTimeout=5000,syncTimeout=5000,connectRetry=3"
  },
  "InternalServiceAuth": {
    "ApiKey": "LOCAL_internal_service_api_key",
    "HeaderName": "X-Internal-Api-Key"
  },
  "BruteForceProtection": {
    "MaxFailedAttemptsBeforeThrottle": 3,
    "MaxFailedAttemptsBeforeLockout": 5,
    "MaxFailedAttemptsPerIp": 10,
    "MaxDistinctIpsPerAccount": 5,
    "AttemptTrackingWindowMinutes": 15,
    "ProgressiveThrottleBaseDelaySeconds": 2,
    "MaxThrottleDelaySeconds": 30,
    "TemporaryLockoutMinutes": 10,
    "IpBlockDurationMinutes": 30,
    "MinimumResponseTimeMs": 800,
    "ResponseTimeVariationMs": 400,
    "EnableSuspiciousPatternLogging": true,
    "CacheKeyPrefix": "bf_protection"
  },
  "TokenCleanup": {
    "Enabled": true,
    "CleanupIntervalHours": 1,
    "RetentionDays": 7,
    "InitialDelayMinutes": 1
  },
  "Seq": {
    "ServerUrl": "http://seq:5341"
  }
}
