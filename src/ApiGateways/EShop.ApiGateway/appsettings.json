{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}      {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/gateway-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "apiKey": ""
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithEnvironmentName" ]
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "EShop.Identity",
    "Audience": "EShop.Services"
  },
  "ForwardedHeaders": {
    "KnownProxies": []
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ]
  },
  "Gateway": {
    "EnableAuditEmailNotifications": false,
    "EnableSimulationFailureEmailNotifications": true,
    "EnableProxyFailureEmailNotifications": true,
    "EnableRateLimitEmailNotifications": true,
    "EnableCriticalSuccessEmailNotifications": true,
    "CriticalSuccessPathPrefixes": [
      "/api/v1/payments",
      "/api/v1/auth/register"
    ],
    "CorrelationHeaderName": "X-Correlation-ID",
    "UserIdHeaderName": "X-User-Id"
  },
  "RateLimiting": {
    "GlobalPermitLimit": 100,
    "GlobalWindowSeconds": 60,
    "SimulationPermitLimit": 30,
    "SimulationWindowSeconds": 60
  },
  "Simulation": {
    "Enabled": true,
    "AllowHeaderOverride": true,
    "Routes": {
      "catalog-route": {
        "PathPrefix": "/api/v1/products",
        "Enabled": true,
        "DelayMs": { "Min": 20, "Max": 100 },
        "ErrorRate": 0.02,
        "FailureModes": [ "500", "503" ],
        "ForcedFailureMode": "",
        "ResponseTemplate": "default"
      },
      "orders-route": {
        "PathPrefix": "/api/v1/orders",
        "Enabled": true,
        "DelayMs": { "Min": 50, "Max": 200 },
        "ErrorRate": 0.05,
        "FailureModes": [ "500", "503", "timeout" ],
        "ForcedFailureMode": "",
        "ResponseTemplate": "orders_list"
      }
    }
  },
  "Email": {
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "From": "gateway@example.com",
    "FromName": "EShop API Gateway",
    "CheckCertificateRevocation": false
  },
  "EmailQueueHealth": {
    "BacklogWarningThreshold": 250,
    "BacklogUnhealthyThreshold": 1000,
    "DroppedWarningThreshold": 1,
    "DroppedUnhealthyThreshold": 50
  },
  "IdentityService": {
    "BaseUrl": "",
    "TimeoutSeconds": 5,
    "ApiKey": "",
    "ApiKeyHeaderName": "X-Internal-Api-Key"
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "identity-account-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v1/account/{**catch-all}"
        }
      },
      "identity-roles-route": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "Admin",
        "Match": {
          "Path": "/api/v1/roles/{**catch-all}"
        }
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/products/{**catch-all}"
        }
      },
      "catalog-categories-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/categories/{**catch-all}"
        }
      },
      "basket-route": {
        "ClusterId": "basket-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v1/basket/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "ordering-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      },
      "payments-route": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "ordering-user-orders-route": {
        "ClusterId": "ordering-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v1/users/{userId}/orders"
        }
      },
      "payment-user-payments-route": {
        "ClusterId": "payment-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v1/users/{userId}/payments"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "d1": { "Address": "http://identity-api:8080/" }
        }
      },
      "catalog-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "d1": { "Address": "http://catalog-api:8080/" }
        }
      },
      "basket-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "d1": { "Address": "http://basket-api:8080/" }
        }
      },
      "ordering-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "d1": { "Address": "http://ordering-api:8080/" }
        }
      },
      "payment-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "d1": { "Address": "http://payment-api:8080/" }
        }
      }
    }
  },
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://localhost:4317",
    "SamplingRatio": 0.1,
    "MetricsEnabled": true
  }
}
