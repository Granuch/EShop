{
  "JwtSettings": {
    "SecretKey": "CHANGE_ME_gateway_jwt_secret_key_32_chars_min"
  },
  "IdentityService": {
    "BaseUrl": "http://localhost:7001"
  },
  "ReverseProxy": {
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:7001/" }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:7004/" }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:7006/" }
        }
      },
      "ordering-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:7005/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:7008/" }
        }
      }
    }
  },
  "Email": {
    "Host": "localhost",
    "Port": 1025,
    "UseSsl": false,
    "From": "gateway@eshop.local",
    "FromName": "EShop API Gateway"
  },
  "Gateway": {
    "EnableAuditEmailNotifications": true,
    "EnableCriticalSuccessEmailNotifications": true,
    "CriticalSuccessPathPrefixes": [
      "/test/orders",
      "/api/v1/payments"
    ]
  },
  "EmailQueueHealth": {
    "BacklogWarningThreshold": 50,
    "BacklogUnhealthyThreshold": 300,
    "DroppedWarningThreshold": 1,
    "DroppedUnhealthyThreshold": 10
  }
}
