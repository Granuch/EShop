**/bin/
**/obj/
**/out/
**/.vs/
**/.vscode/
**/TestResults/

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates

# Logs
*.log
logs/
**/logs/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo
*~

# Package managers
**/node_modules/
**/packages/

# Tests
**/tests/
**/*.Tests/
**/*.UnitTests/
**/*.IntegrationTests/

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml
.env*

# Scripts (not needed in container)
scripts/

# Monitoring (not needed in container)
monitoring/

# Redis data (not needed in container)
redis/

