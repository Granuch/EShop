    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 75 },
      "id": 206,
      "panels": [],
      "title": "Deadlocks & Conflicts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "spanNulls": true }, "unit": "short" } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 76 },
      "id": 70,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(pg_stat_database_deadlocks{job=~\"$pg_job\", datname=~\"eshop_.*\"}[$__rate_interval])", "legendFormat": "{{ job }} deadlocks/s", "refId": "A" },
        { "expr": "rate(pg_stat_database_conflicts{job=~\"$pg_job\", datname=~\"eshop_.*\"}[$__rate_interval])", "legendFormat": "{{ job }} conflicts/s", "refId": "B" }
      ],
      "title": "Deadlocks & Conflicts Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "spanNulls": true }, "unit": "short" } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 76 },
      "id": 71,
