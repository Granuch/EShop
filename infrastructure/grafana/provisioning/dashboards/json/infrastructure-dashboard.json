{
  "annotations": { "list": [] },
  "description": "Infrastructure health — .NET Runtime (USE), Kestrel, Database (Npgsql), GC, Thread Pool",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "asDropdown": true, "icon": "external link", "includeVars": true, "keepTime": true, "tags": ["eshop"], "title": "Service Dashboards", "type": "dashboards" }
  ],
  "panels": [
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "panels": [], "title": "CPU & Memory", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "spanNulls": true }, "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:dotnet_cpu_usage:rate5m{job=~\"$service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "CPU Usage (rate of CPU seconds)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "spanNulls": true }, "unit": "decbytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:dotnet_memory_working_set:bytes{job=~\"$service\"}", "legendFormat": "{{ job }} working set", "refId": "A" },
        { "expr": "instance:dotnet_gc_heap_size:bytes{job=~\"$service\"}", "legendFormat": "{{ job }} GC heap", "refId": "B" }
      ],
      "title": "Memory",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 101, "panels": [], "title": "Garbage Collection", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "percentunit" } },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 10 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:dotnet_gc_pause:rate5m{job=~\"$service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "GC Pause Time (% of wall clock)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "ops" } },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 10 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(dotnet_gc_collections_total{job=~\"$service\"}[5m])) by (job, generation)", "legendFormat": "{{ job }} gen{{ generation }}", "refId": "A" }
      ],
      "title": "GC Collections Rate (by generation)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "decbytes" } },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 10 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:dotnet_gc_heap_fragmentation:bytes{job=~\"$service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "GC Heap Fragmentation",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }, "id": 102, "panels": [], "title": "Thread Pool & Contention", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "short" } },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 18 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:dotnet_threadpool_threads:count{job=~\"$service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "Thread Pool Threads",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "ops" } },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 18 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:dotnet_threadpool_queue_length:rate5m{job=~\"$service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "Thread Pool Queue Growth Rate (saturation)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "ops" } },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 18 },
      "id": 22,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:dotnet_lock_contentions:rate5m{job=~\"$service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "Lock Contention Rate",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }, "id": 103, "panels": [], "title": "Exceptions", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 20 }, "unit": "ops", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 5 }] } } },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 26 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:dotnet_exceptions:rate5m{job=~\"$service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "Exception Rate",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 }, "id": 104, "panels": [], "title": "Kestrel (Web Server)", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "short" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 34 },
      "id": 40,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:kestrel_active_connections:count{job=~\"$service\"}", "legendFormat": "{{ job }} active", "refId": "A" },
        { "expr": "instance:kestrel_queued_connections:count{job=~\"$service\"}", "legendFormat": "{{ job }} queued", "refId": "B" }
      ],
      "title": "Kestrel Connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "s" } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 34 },
      "id": 41,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:kestrel_connection_duration_p95:rate5m{job=~\"$service\"}", "legendFormat": "{{ job }} P95", "refId": "A" }
      ],
      "title": "Kestrel Connection Duration P95",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }, "id": 105, "panels": [], "title": "Database (PostgreSQL via Npgsql)", "type": "row" },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "s" } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 42 },
      "id": 50,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "instance:npgsql_connection_create_p95:rate5m{job=~\"$service\"}", "legendFormat": "{{ job }} P95", "refId": "A" },
        { "expr": "instance:npgsql_connection_create_p99:rate5m{job=~\"$service\"}", "legendFormat": "{{ job }} P99", "refId": "B" }
      ],
      "title": "DB Connection Create Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "percentunit", "max": 1 } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 42 },
      "id": 51,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "npgsql_db_client_operation_npgsql_prepared_ratio{job=~\"$service\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "Prepared Statement Ratio",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["eshop", "infrastructure", "runtime"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(dotnet_process_memory_working_set_bytes, job)",
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": { "query": "label_values(dotnet_process_memory_working_set_bytes, job)" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EShop Infrastructure Health",
  "uid": "eshop-infrastructure",
  "version": 1
}
