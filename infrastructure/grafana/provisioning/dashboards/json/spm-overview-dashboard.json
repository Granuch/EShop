{
  "annotations": { "list": [] },
  "description": "Service Performance Monitoring — RED metrics, SLO tracking, and trace correlation across all EShop microservices",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["eshop"],
      "title": "Service Dashboards",
      "type": "dashboards"
    },
    {
      "icon": "bolt",
      "title": "Jaeger Traces",
      "type": "link",
      "url": "http://localhost:16686/search?service=${service:raw}",
      "targetBlank": true
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "index": 1, "text": "DOWN" }, "1": { "color": "green", "index": 0, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{job=\"identity-api-1\"}", "legendFormat": "Identity API", "refId": "A" }],
      "title": "Identity API",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "index": 1, "text": "DOWN" }, "1": { "color": "green", "index": 0, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{job=\"catalog-api\"}", "legendFormat": "Catalog API", "refId": "A" }],
      "title": "Catalog API",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "index": 1, "text": "DOWN" }, "1": { "color": "green", "index": 0, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "up{job=\"redis\"}", "legendFormat": "Redis", "refId": "A" }],
      "title": "Redis",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(service:http_requests:rate5m) or vector(0)", "legendFormat": "Total RPS", "refId": "A" }],
      "title": "Total Request Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] }, "max": 1 } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(service:http_errors_5xx:rate5m) / sum(service:http_requests:rate5m) or vector(0)", "legendFormat": "Error %", "refId": "A" }],
      "title": "Global Error Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "max(service:http_latency_p95:rate5m) or vector(0)", "legendFormat": "P95", "refId": "A" }],
      "title": "Worst P95 Latency",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "RED Metrics — Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "spanNulls": true }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "service:http_requests:rate5m", "legendFormat": "{{ service }}", "refId": "A" }
      ],
      "title": "Request Rate by Service",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "panels": [],
      "title": "RED Metrics — Errors",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "spanNulls": true }, "unit": "percentunit", "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "service:http_error_ratio:rate5m", "legendFormat": "{{ service }} error %", "refId": "A" },
        { "expr": "vector(0.001)", "legendFormat": "SLO (99.9%)", "refId": "SLO" }
      ],
      "title": "Error Ratio by Service (5xx / total)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "spanNulls": true }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(http_requests_received_total{code=~\"5..\"}[5m])) by (service, code) or vector(0)", "legendFormat": "{{ service }} {{ code }}", "refId": "A" }
      ],
      "title": "5xx Errors by Service & Status Code",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "panels": [],
      "title": "RED Metrics — Duration",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 10, "spanNulls": true }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "service:http_latency_p50:rate5m", "legendFormat": "{{ service }} P50", "refId": "A" },
        { "expr": "service:http_latency_p95:rate5m", "legendFormat": "{{ service }} P95", "refId": "B" },
        { "expr": "service:http_latency_p99:rate5m", "legendFormat": "{{ service }} P99", "refId": "C" }
      ],
      "title": "Latency Percentiles by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 0 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "service_endpoint:http_latency_p95:rate5m{service=~\"$service\"}", "legendFormat": "{{ method }} {{ endpoint }}", "refId": "A" }
      ],
      "title": "P95 Latency by Endpoint ($service)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "panels": [],
      "title": "SLO — Error Budget (Target: 99.9%)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.25 }, { "color": "yellow", "value": 0.5 }, { "color": "green", "value": 0.75 }] }, "min": 0, "max": 1 } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 33 },
      "id": 40,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "targets": [
        { "expr": "clamp_min(1 - (service:slo_errors_per_request:ratio_rate1h / 0.001), 0) or vector(1)", "legendFormat": "{{ service }}", "refId": "A" }
      ],
      "title": "Error Budget Remaining (1h window)",
      "description": "Percentage of error budget remaining. 100% = no errors. 0% = budget exhausted.",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15, "spanNulls": true }, "unit": "percentunit" } },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 33 },
      "id": 41,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "service:slo_errors_per_request:ratio_rate5m", "legendFormat": "{{ service }} (5m)", "refId": "A" },
        { "expr": "service:slo_errors_per_request:ratio_rate1h", "legendFormat": "{{ service }} (1h)", "refId": "B" },
        { "expr": "vector(0.001)", "legendFormat": "SLO Target (0.1%)", "refId": "SLO" }
      ],
      "title": "Error Ratio vs SLO Target",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 105,
      "panels": [],
      "title": "Runtime Metrics (OpenTelemetry)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "decbytes" } },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 40 },
      "id": 50,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "dotnet_process_memory_working_set_bytes{job=~\".*-otel\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "Process Memory (Working Set)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "short" } },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 40 },
      "id": 51,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(dotnet_gc_collections_total{job=~\".*-otel\"}[5m])", "legendFormat": "{{ job }} gen{{ generation }}", "refId": "A" }
      ],
      "title": "GC Collections Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 15 }, "unit": "short" } },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 40 },
      "id": 52,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "kestrel_active_connections{job=~\".*-otel\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ],
      "title": "Active Kestrel Connections",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["eshop", "spm", "red", "slo"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_requests_received_total, service)",
        "includeAll": true,
        "multi": false,
        "name": "service",
        "query": { "query": "label_values(http_requests_received_total, service)" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "EShop SPM Overview",
  "uid": "eshop-spm-overview",
  "version": 1
}
