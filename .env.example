# ============================================
# EShop Docker Environment Variables
# Copy this file to .env and configure your values
# IMPORTANT: Never commit .env to version control!
# ============================================

# ============================================
# Application Environment
# ============================================
ASPNETCORE_ENVIRONMENT=Sandbox
LOG_LEVEL=Information
IDENTITY_REQUIRE_CONFIRMED_EMAIL=false

# ============================================
# Identity Seed Admin (Development/Sandbox only)
# ============================================
IDENTITY_SEED_ADMIN_EMAIL=admin@eshop.com
IDENTITY_SEED_ADMIN_PASSWORD=Admin123!

# ============================================
# PostgreSQL Database
# ============================================
POSTGRES_DB=eshop_identity
POSTGRES_USER=postgres
POSTGRES_PASSWORD=qweasdz1
POSTGRES_PORT=5432

# ============================================
# Redis Cache
# ============================================
REDIS_PASSWORD=4ZA2nxObXTHmLKVFvUcM6IeqDBQaGhuf
REDIS_PORT=6379

# ============================================
# JWT Settings
# IMPORTANT: SecretKey must be at least 32 characters
# ============================================
JWT_SECRET_KEY=duHbxp5ADlMhUk95kPVwdk8tgml3vVF0cDSSZ4KfaupX8oxJ3erikMDLHiFKj0gxOKis2mlaStiHSlbglngbjy
JWT_ISSUER=EShop.Identity
JWT_AUDIENCE=EShop.Services
JWT_ACCESS_TOKEN_EXPIRATION=60
JWT_REFRESH_TOKEN_EXPIRATION=7

# ============================================
# Catalog PostgreSQL Database
# ============================================
CATALOG_POSTGRES_DB=eshop_catalog
CATALOG_POSTGRES_USER=postgres
CATALOG_POSTGRES_PASSWORD=qweasdz1
CATALOG_POSTGRES_PORT=5433

# ============================================
# Ordering PostgreSQL Database
# ============================================
ORDERING_POSTGRES_DB=eshop_ordering
ORDERING_POSTGRES_USER=postgres
ORDERING_POSTGRES_PASSWORD=qweasdz1
ORDERING_POSTGRES_PORT=5434

# ============================================
# RabbitMQ
# ============================================
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN_1=http://localhost:3000
CORS_ORIGIN_2=https://localhost:3000

# ============================================
# Service Ports
# ============================================
IDENTITY_API_PORT_1=7001
CATALOG_API_PORT=7004
ORDERING_API_PORT=7005
SEQ_UI_PORT=5341
SEQ_INGEST_PORT=5342
REDIS_EXPORTER_PORT=9121
REDIS_COMMANDER_PORT=8081
PG_EXPORTER_IDENTITY_PORT=9187
PG_EXPORTER_CATALOG_PORT=9188
PG_EXPORTER_ORDERING_PORT=9189
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ============================================
# Grafana Admin Credentials
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ============================================
# Optional: Cloud Provider Settings
# ============================================
# For Azure/AWS/GCP, uncomment and configure:
# CLOUD_PROVIDER=azure|aws|gcp
# REDIS_CLOUD_CONNECTION_STRING=your-cloud-redis-connection

# Jaeger (UI only — traces are received via OTEL Collector)
JAEGER_UI_PORT=16686

# OpenTelemetry Collector (receives traces from services, forwards to Jaeger)
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# RedisInsight
REDIS_INSIGHT_PORT=8001

# OpenTelemetry
# Sampling ratio: 1.0 = 100% (dev), 0.1 = 10% (production)
# Lower values reduce Jaeger/Seq memory usage under high RPS
OTEL_SAMPLING_RATIO=0.1
